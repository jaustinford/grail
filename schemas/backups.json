{
  "title": "grail backups",
  "description": "main configuration",
  "properties": {
    "backups": {
      "type": "object",
      "description": "parent object",
      "properties": {
        "non_checksum_exts": {
          "type": "array",
          "description": "list of exts to not perform checksum against and use instead simple size comparison.",
          "items": {
            "type": "string",
            "description": "file extension"
          }
        },
        "objects": {
          "type": "array",
          "description": "list of backup objects",
          "items": {
            "type": "object",
            "description": "object item",
            "properties": {
              "name": {
                "type": "string",
                "description": "name of object",
                "pattern": "^(raid-[1-4]|app)$"
              },
              "targets": {
                "type": "array",
                "description": "targets within object",
                "items": {
                  "type": "string",
                  "description": "folder path of target"
                }
              }
            },
            "required": [
              "name",
              "targets"
            ]
          }
        },
        "logging": {
          "type": "object",
          "description": "configure project logging",
          "properties": {
            "format": {
              "type": "object",
              "description": "log formatting timestamp",
              "properties": {
                "banner": {
                  "type": "string",
                  "description": "banner format for logs"
                },
                "date": {
                  "type": "string",
                  "description": "log formatting timestamp date element",
                  "pattern": "^%Y(-|_|:)%m(-|_|:)%d$"
                },
                "time": {
                  "type": "string",
                  "description": "log formatting timestamp time element",
                  "pattern": "^%H(-|_|:)%M(-|_|:)%S$"
                }
              },
              "required": [
                "banner",
                "date",
                "time"
              ]
            }
          },
          "required": ["format"]
        }
      },
      "required": [
        "non_checksum_exts",
        "objects",
        "logging"
      ]
    }
  }
}
